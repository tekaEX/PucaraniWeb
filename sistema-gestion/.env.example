# Copia este archivo como ".env.local" y completa con los datos de tu proyecto Supabase.
# En Supabase: Project Settings -> Data API / API Keys

# URL del proyecto (ej. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (publishable). Es segura para el navegador.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
