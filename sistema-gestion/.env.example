# Copia este archivo como ".env.local" y completa con los datos de tu proyecto Supabase.
# En Supabase: Project Settings -> Data API / API Keys

# URL del proyecto (ej. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (publishable). Es segura para el navegador.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Integración SII (SimpleAPI) ---
# Master Key de SimpleAPI (identifica tu app; va en el header Authorization).
SIMPLEAPI_KEY=

# Llave para cifrar la contraseña del certificado digital (AES-256-GCM).
# 32 bytes en hexadecimal (64 caracteres). Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
